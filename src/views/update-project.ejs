<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

 <form action="/update-project/<%= projectDetails.service_project_id %>" method="POST">
    <div class="form-group">
      <label for="name">Project Title</label>
      <input
        type="text"
        id="title"
        name="title"
        value="<%= projectDetails.title %>"
        maxlength="150"
        required
      />
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea
        id="description"
        name="description"
        maxlength="500"
        required
      ><%= projectDetails.description %></textarea>
    </div>

    <div class="form-group">
      <label for="location">Location</label>
      <input
        type="text"
        id="address"
        name="address"
        maxlength="255"
        value="<%= projectDetails.address %> "
        required
      />
    </div>

    <div class="form-group">
      <label for="date">Date</label>
      <input
        type="date"
        id="date"
        name="date"
        value="<%= projectDetails.date %> "
        required
      />
    </div>

    <div class="form-group">
      <label for="organizationId">Organization</label>
      <select
        id="organizationId"
        name="organizationId"
        required
      >
        <option value="<%= projectDetails.organization_id %>"><%= projectDetails.organization_name %></option>
        <% organizations.forEach(org => { %>
          <option value="<%= org.organization_id %>"><%= org.name %></option>
        <% }); %>
      </select>
    </div>


    <button type="submit">Update Project</button>
  </form>

</main>
<%- include('partials/footer') %>