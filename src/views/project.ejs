 <%- include('partials/header') %>

<main>
    
    <h1><%= title %></h1>
    <h2><%= projectDetails.title %></h2>
        
        
        <div class="project-card">     
            <p style="color:aqua">What:</p>
            <p><%= projectDetails.description %></p>
            <p style="color:aqua">Where:</p>
            <p><%= projectDetails.address %></p>
